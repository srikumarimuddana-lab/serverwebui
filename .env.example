# =============================================================================
# Server WebUI - Master environment configuration
# Copy this file to `.env` and fill in the values for your deployment.
# =============================================================================

# ---- REQUIRED ----------------------------------------------------------------
# Secret used to sign JWT tokens. Must be set; never share or commit.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-a-long-random-string

# ---- DEFAULT ADMIN BOOTSTRAP -------------------------------------------------
# On first startup (when the users table is empty) the master process will
# create an initial admin account using these values so the web UI is usable.
# If DEFAULT_ADMIN_PASSWORD is not set, no user is created and the UI cannot
# be logged into until an admin is created out-of-band.
# IMPORTANT: change the password from the UI immediately after first login.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-on-first-login

# ---- OPTIONAL ----------------------------------------------------------------
# SQLAlchemy database URL. Defaults to a local SQLite file.
DATABASE_URL=sqlite+aiosqlite:///./server_webui.db

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000

# Network binding for the master API.
BIND_HOST=0.0.0.0
BIND_PORT=8400

# Directory holding the master's TLS certificates.
CERT_DIR=/etc/server-webui/certs
